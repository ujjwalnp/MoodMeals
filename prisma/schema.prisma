// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==============================
// USER MANAGEMENT
// ==============================
model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String   // Hashed password
  role      UserRole @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  addresses   Address[]
  orders      Order[]
  appReviews  AppReview[]
  cart        Cart?

  @@map("users")
}

enum UserRole {
  USER
  ADMIN
}

// ==============================
// ADDRESS MANAGEMENT
// ==============================
model Address {
  id           String  @id @default(cuid())
  userId       String
  addressLine1 String
  addressLine2 String?
  city         String @default("Hetauda")
  state        String @default("Bagmati")
  postalCode   String
  country      String  @default("Nepal")
  landmark     String?
  phoneNumber  String  // Delivery contact number
  isDefault    Boolean @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relationships
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@unique([userId, addressLine1, city, postalCode])
  @@map("addresses")
}

// ==============================
// MENU MANAGEMENT
// ==============================
model MenuItem {
  id              String         @id @default(cuid())
  name            String
  description     String?
  price           Decimal        @db.Decimal(10, 2)
  isDiscount      Boolean        @default(false)
  discountedPrice Decimal?       @db.Decimal(10, 2)
  preparationTime  Int           // Time in minutes
  popularityTag   PopularityTag?
  rating          Float?         @default(0) // Average rating (0-5)
  slug            String         @unique
  isVeg           Boolean        @default(true)
  image           String?
  isAvailable     Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Relationships
  orderItems  OrderItem[]
  itemRatings ItemRating[]  // Fixed: This now has opposite relation
  cartItems   CartItem[]

  @@index([isVeg])
  @@index([popularityTag])
  @@index([isAvailable])
  @@map("menu_items")
}

enum PopularityTag {
  POPULAR
  CHEF_SPECIAL
  TRENDING
  BESTSELLER
  FAN_FAVORITE
}


// ==============================
// ORDER MANAGEMENT
// ==============================
model Order {
  id              String         @id @default(cuid())
  orderNumber     String         @unique
  userId          String
  addressId       String
  status          OrderStatus    @default(PENDING)
  paymentStatus   PaymentStatus  @default(UNPAID)
  subtotal        Decimal        @db.Decimal(10, 2)
  deliveryCharge  Decimal        @default(0) @db.Decimal(10, 2)
  totalAmount     Decimal        @db.Decimal(10, 2)
  discountAmount  Decimal        @default(0) @db.Decimal(10, 2)
  specialInstructions String?
  preparationStartedAt DateTime?
  readyAt         DateTime?
  deliveredAt     DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Relationships
  user        User         @relation(fields: [userId], references: [id])
  address     Address      @relation(fields: [addressId], references: [id])
  orderItems  OrderItem[]
  payment     Payment?
  appReview   AppReview?
  deliveryTracking DeliveryTracking?

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
  FAILED
}

// ==============================
// ORDER ITEMS
// ==============================
model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  menuItemId String
  quantity   Int      @default(1)
  unitPrice  Decimal  @db.Decimal(10, 2)
  totalPrice Decimal  @db.Decimal(10, 2)
  createdAt  DateTime @default(now())

  // Relationships
  order       Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem    MenuItem    @relation(fields: [menuItemId], references: [id])
  itemRating  ItemRating? // One-to-one relationship

  @@unique([orderId, menuItemId])
  @@map("order_items")
}

// ==============================
// ITEM RATING (Stars only, per ordered item)
// ==============================
model ItemRating {
  id          String   @id @default(cuid())
  orderItemId String   @unique
  rating      Int      // 1-5 stars
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relationships
  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  menuItem  MenuItem  @relation(fields: [menuItemId], references: [id]) // Fixed: Added this relation
  
  // Added menuItemId to link back to MenuItem
  menuItemId String

  @@map("item_ratings")
}

// ==============================
// APP REVIEW (Stars + Text for overall experience)
// ==============================
model AppReview {
  id          String      @id @default(cuid())
  orderId     String      @unique
  userId      String
  rating      Int         // 1-5 stars
  title       String?
  description String?
  tags        ReviewTag[]
  isVerified  Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Relationships
  order Order @relation(fields: [orderId], references: [id])
  user  User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([rating])
  @@map("app_reviews")
}

enum ReviewTag {
  EXCELLENT_SERVICE
  FAST_DELIVERY
  GREAT_TASTE
  GOOD_PACKAGING
  VALUE_FOR_MONEY
  NEEDS_IMPROVEMENT
  LATE_DELIVERY
  WRONG_ORDER
}

// ==============================
// PAYMENT MANAGEMENT
// ==============================
model Payment {
  id              String        @id @default(cuid())
  orderId         String        @unique
  amount          Decimal       @db.Decimal(10, 2)
  method          PaymentMethod
  status          PaymentStatus @default(UNPAID)
  transactionId   String?       @unique
  gatewayResponse Json?         
  paidAt          DateTime?
  refundAmount    Decimal?      @db.Decimal(10, 2)
  refundedAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relationships
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payments")
}

enum PaymentMethod {
  CASH_ON_DELIVERY
  KHALTI
  CREDIT_CARD
  DEBIT_CARD
  UPI
  NET_BANKING
  WALLET
}

// ==============================
// DELIVERY TRACKING
// ==============================
model DeliveryTracking {
  id          String         @id @default(cuid())
  orderId     String         @unique
  driverName  String?
  driverPhone String?
  currentLat  Float?
  currentLng  Float?
  status      DeliveryStatus @default(PENDING)
  lastUpdated DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  // Relationships
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("delivery_tracking")
}

enum DeliveryStatus {
  PENDING
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  FAILED
}

// ==============================
// CART
// ==============================
model Cart {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  cartItems  CartItem[]

  @@map("carts")
}

model CartItem {
  id         String   @id @default(cuid())
  cartId     String
  menuItemId String
  quantity   Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relationships
  cart     Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])

  @@unique([cartId, menuItemId])
  @@map("cart_items")
}